// Place your settings in this file to overwrite default and user settings.
{
  "editor.detectIndentation": false,
  "editor.insertSpaces": true,
  "editor.tabSize": 2,
  "editor.formatOnSave": true,
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "files.associations": {
    "*.json": "jsonc"
  },
  "npm.exclude": [
    "**/tests/**",
    "**/xpacks/**"
  ],
  "markdownlint.config": {
    "MD041": false
  },
  "spellright.language": [
    "en_GB"
  ],
  "spellright.notificationClass": "warning",
  "cSpell.ignoreWords": [
    "Codacy",
    "Ionescu",
    "Liviu",
    "autotools",
    "buildtype",
    "cleanups",
    "cmake",
    "cmsis",
    "cortexm",
    "cpptools",
    "ctest",
    "diag",
    "eabi",
    "liquidjs",
    "loglevel",
    "mhutchie",
    "minsize",
    "mkdir",
    "npmjs",
    "postversion",
    "semihosted",
    "semihosting",
    "spellright",
    "subaction",
    "taskdef",
    "twxs",
    "vscodeignore",
    "vsix",
    "xpack",
    "xpacks"
  ]
}
